rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Gloabl deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Publicly readable analytics and ratings
    match /nosafix_tools/{toolId} {
      allow read: if true;
      allow write: if false; // Writes proxied through server.ts API
      
      match /ratings/{userId} {
        allow read: if true;
        allow write: if false; // Writes proxied through server.ts API
      }
    }

    // Publicly readable Chrome Store stats
    match /extensions_stats/{extensionId} {
      allow read: if true;
      allow write: if false; // Updates handled by server cron job
    }
  }
}
